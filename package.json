{
  "name": "lacurva-mundial",
  "version": "1.0.0",
  "private": true,
  "description": "World Cup fixture and prediction app with JSON persistence.",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "start": "PORT=3001 node server.js",
    "dev": "PORT=3001 node --watch server.js",
    "build:css": "tailwindcss -i public/css/tailwind.css -o public/css/tailwind.output.css",
    "watch:css": "tailwindcss -i public/css/tailwind.css -o public/css/tailwind.output.css --watch"
  },
  "dependencies": {
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.18.0",
    "helmet": "^8.2.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "tailwindcss": "^4.3.1"
  }
}
